<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="OI|[9VsH(x|8DOP0adIj" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="L^sx*!mkR2dg${}Y+Dew"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace FyzikalniSenzory {" line1="" line2="    // ==========================================" line3="    // --- 1. TEPLOMĚR (DS18B20) ---" line4="    // ==========================================" line5="" line6="    /**" line7="     * Změří teplotu z DS18B20." line8="     * Vyžaduje připojenou knihovnu dstemp." line9="     * @param pin Pin připojený k senzoru" line10="     */" line11="    //% block=&quot;změřit teplotu (°C) na pinu %pin&quot;" line12="    //% group=&quot;1. Teplota&quot;" line13="    //% weight=100" line14="    export function zmeritTeplotu(pin: DigitalPin): number {" line15="        return dstemp.celsius(pin);" line16="    }" line17="" line18="    /**" line19="     * Změří teplotu, pošle ji do grafu a počká 1 sekundu." line20="     * @param pin Pin připojený k senzoru" line21="     */" line22="    //% block=&quot;změřit teplotu a kresli graf (pin %pin)&quot;" line23="    //% group=&quot;1. Teplota&quot;" line24="    //% weight=99" line25="    export function zmeritTeplotuAGraf(pin: DigitalPin): void {" line26="        let t = zmeritTeplotu(pin);" line27="        serial.writeValue(&quot;Teplota (C)&quot;, t);" line28="        basic.pause(1000);" line29="    }" line30="" line31="" line32="    // ==========================================" line33="    // --- 2. SILOMĚR (HX711) ---" line34="    // ==========================================" line35="" line36="    // Proměnné pro naši logiku (offset a měřítko v Newtonech)" line37="    let my_offset = 0;" line38="" line39="    // !!! ZDE UPRAV KALIBRACI !!! " line40="    // Kolik dílků senzoru odpovídá 1 Newtonu?" line41="    // Tip: Změř známé závaží, podívej se na raw hodnotu a vyděl to." line42="    let my_scale = 1000;" line43="" line44="    // Pamatujeme si poslední piny pro funkci Tára" line45="    let last_dout = DigitalPin.P15;" line46="    let last_sck = DigitalPin.P16;" line47="" line48="    /**" line49="     * Změří sílu v Newtonech. " line50="     * Automaticky nastaví piny a změří hodnotu." line51="     * @param doutPin Pin pro DT (Data)" line52="     * @param sckPin Pin pro SCK (Clock)" line53="     */" line54="    //% block=&quot;změřit sílu (N) | DT %doutPin | SCK %sckPin&quot;" line55="    //% group=&quot;2. Síla (Siloměr)&quot;" line56="    //% weight=90" line57="    export function zmeritSilu(doutPin: DigitalPin, sckPin: DigitalPin): number {" line58="        // 1. Uložení pinů pro budoucí použití (tára)" line59="        last_dout = doutPin;" line60="        last_sck = sckPin;" line61="" line62="        // 2. Nastavení pinů v externí knihovně HX711" line63="        // Používáme přesné názvy z tvého souboru HX711.ts" line64="        HX711.SetPIN_DOUT(doutPin);" line65="        HX711.SetPIN_SCK(sckPin);" line66="" line67="        // 3. Inicializace (nastaví gain 128 a probudí čip)" line68="        HX711.begin();" line69="" line70="        // 4. Přečtení surové hodnoty" line71="        // Funkce read() v té knihovně vrací surové číslo (raw 24-bit integer)" line72="        let raw_val = HX711.read();" line73="" line74="        // 5. Výpočet Newtonů: (raw - offset) / měřítko" line75="        if (my_scale == 0) my_scale = 1;" line76="" line77="        return Math.idiv((raw_val - my_offset), my_scale);" line78="    }" line79="" line80="    /**" line81="     * Změří sílu, pošle ji do grafu a počká 1 sekundu." line82="     */" line83="    //% block=&quot;změřit sílu a kresli graf | DT %doutPin | SCK %sckPin&quot;" line84="    //% group=&quot;2. Síla (Siloměr)&quot;" line85="    //% weight=89" line86="    export function zmeritSiluAGraf(doutPin: DigitalPin, sckPin: DigitalPin): void {" line87="        let f = zmeritSilu(doutPin, sckPin);" line88="        serial.writeValue(&quot;Sila (N)&quot;, f);" line89="        basic.pause(1000);" line90="    }" line91="" line92="    /**" line93="     * Vynuluje siloměr (tára). " line94="     * Použije piny, které byly nastaveny v posledním měření." line95="     */" line96="    //% block=&quot;vynulovat siloměr (tára)&quot;" line97="    //% group=&quot;2. Síla (Siloměr)&quot;" line98="    //% weight=88" line99="    export function tarovatSilomer(): void {" line100="        // Pro jistotu znovu nastavíme piny (kdyby se mezitím změnily)" line101="        HX711.SetPIN_DOUT(last_dout);" line102="        HX711.SetPIN_SCK(last_sck);" line103="        HX711.begin();" line104="" line105="        let suma = 0;" line106="        // Uděláme 3 měření pro průměr" line107="        for (let i = 0; i &lt; 3; i++) {" line108="            suma += HX711.read();" line109="            basic.pause(50);" line110="        }" line111="        my_offset = Math.idiv(suma, 3);" line112="    }" line113="" line114="    /**" line115="     * Pokročilá kalibrace: Kolik surových jednotek odpovídá 1 Newtonu?" line116="     */" line117="    //% block=&quot;kalibrovat siloměr (dílků na 1 N): %meritko&quot;" line118="    //% group=&quot;2. Síla (Siloměr)&quot;" line119="    //% advanced=true" line120="    export function nastavitMeritko(meritko: number): void {" line121="        if (meritko == 0) meritko = 1;" line122="        my_scale = meritko;" line123="    }" line124="" line125="" line126="    // ==========================================" line127="    // --- 3. VZDÁLENOST (HC-SR04) ---" line128="    // ==========================================" line129="" line130="    /**" line131="     * Změří vzdálenost v cm." line132="     * @param trigPin Pin Trig" line133="     * @param echoPin Pin Echo" line134="     */" line135="    //% block=&quot;změřit vzdálenost (cm) | Trig %trigPin | Echo %echoPin&quot;" line136="    //% group=&quot;3. Vzdálenost (Sonar)&quot;" line137="    //% weight=80" line138="    export function zmeritVzdalenost(trigPin: DigitalPin, echoPin: DigitalPin): number {" line139="        pins.digitalWritePin(trigPin, 0);" line140="        control.waitMicros(2);" line141="        pins.digitalWritePin(trigPin, 1);" line142="        control.waitMicros(10);" line143="        pins.digitalWritePin(trigPin, 0);" line144="" line145="        const d = pins.pulseIn(echoPin, PulseValue.High, 23200);" line146="        let vzdalenost = Math.idiv(d, 58);" line147="" line148="        if (vzdalenost &lt;= 0) return 0;" line149="        return vzdalenost;" line150="    }" line151="" line152="    /**" line153="     * Změří vzdálenost, pošle ji do grafu a počká 1 sekundu." line154="     * @param trigPin Pin Trig" line155="     * @param echoPin Pin Echo" line156="     */" line157="    //% block=&quot;změřit vzdálenost a kresli graf | Trig %trigPin | Echo %echoPin&quot;" line158="    //% group=&quot;3. Vzdálenost (Sonar)&quot;" line159="    //% weight=79" line160="    export function zmeritVzdalenostAGraf(trigPin: DigitalPin, echoPin: DigitalPin): void {" line161="        let dist = zmeritVzdalenost(trigPin, echoPin);" line162="        serial.writeValue(&quot;Vzdalenost (cm)&quot;, dist);" line163="        basic.pause(1000);" line164="    }" line165="}" numlines="166"></mutation></block></statement></block></xml>