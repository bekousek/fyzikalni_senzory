<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="oIkP$dTRl=Ux01n+1G%;" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="f=.9G|Cm411~$SvD^#T("><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace FyzikalniSenzory {" line1="" line2="    export enum RychlostniJednotka {" line3="        //% block=&quot;m/s&quot;" line4="        Ms," line5="        //% block=&quot;km/h&quot;" line6="        Kmh" line7="    }" line8="" line9="    export enum VzdalenostniJednotka {" line10="        //% block=&quot;cm&quot;" line11="        Cm," line12="        //% block=&quot;m&quot;" line13="        M" line14="    }" line15="" line16="    // ==========================================" line17="    // --- 1. TEPLOMĚR (DS18B20) ---" line18="    // ==========================================" line19="" line20="    //% block=&quot;změřená teplota (°C) na pinu %pin&quot;" line21="    //% group=&quot;1. Teplota&quot;" line22="    //% weight=100" line23="   " line24="    export function zmeritTeplotu(pin: DigitalPin): number {" line25="        return dstemp.celsius(pin);" line26="    }" line27="" line28="    //% block=&quot;změřit teplotu a kreslit graf (pin %pin)&quot;" line29="    //% group=&quot;1. Teplota&quot;" line30="    //% weight=99" line31="    export function zmeritTeplotuAGraf(pin: DigitalPin): void {" line32="        let t = zmeritTeplotu(pin);" line33="        serial.writeValue(&quot;Teplota (C)&quot;, t);" line34="        basic.pause(1000);" line35="    }" line36="" line37="" line38="    // ==========================================" line39="    // --- 2. SILOMĚR (HX711) ---" line40="    // ==========================================" line41="" line42="    let my_offset = 0;" line43="    let my_scale = -10578;" line44="" line45="    let last_dout = DigitalPin.P15;" line46="    let last_sck = DigitalPin.P16;" line47="" line48="    //% block=&quot;změřená síla (N) | DT %doutPin | SCK %sckPin&quot;" line49="    //% group=&quot;2. Síla&quot;" line50="    //% weight=90" line51="    export function zmeritSilu(doutPin: DigitalPin, sckPin: DigitalPin): number {" line52="        last_dout = doutPin;" line53="        last_sck = sckPin;" line54="" line55="        HX711.SetPIN_DOUT(doutPin);" line56="        HX711.SetPIN_SCK(sckPin);" line57="        HX711.begin();" line58="" line59="        // Medián (3 hodnoty)" line60="        let val1 = HX711.read();" line61="        let val2 = HX711.read();" line62="        let val3 = HX711.read();" line63="" line64="        let maxVal = Math.max(val1, Math.max(val2, val3));" line65="        let minVal = Math.min(val1, Math.min(val2, val3));" line66="        let raw_median = (val1 + val2 + val3) - maxVal - minVal;" line67="" line68="        if (my_scale == 0) my_scale = 1;" line69="        let val = (raw_median - my_offset) / my_scale;" line70="" line71="        return Math.round(val * 10) / 10;" line72="    }" line73="" line74="    //% block=&quot;změřit sílu a kreslit graf | DT %doutPin | SCK %sckPin&quot;" line75="    //% group=&quot;2. Síla&quot;" line76="    //% weight=89" line77="    export function zmeritSiluAGraf(doutPin: DigitalPin, sckPin: DigitalPin): void {" line78="        let f = zmeritSilu(doutPin, sckPin);" line79="        serial.writeValue(&quot;Sila (N)&quot;, f);" line80="        basic.pause(50);" line81="    }" line82="" line83="    //% block=&quot;vynulovat siloměr (tára)&quot;" line84="    //% group=&quot;2. Síla&quot;" line85="    //% weight=88" line86="    export function tarovatSilomer(): void {" line87="        HX711.SetPIN_DOUT(last_dout);" line88="        HX711.SetPIN_SCK(last_sck);" line89="        HX711.begin();" line90="" line91="        let pole: number[] = [];" line92="        for (let i = 0; i &lt; 5; i++) {" line93="            pole.push(HX711.read());" line94="            basic.pause(10);" line95="        }" line96="        pole.sort((a, b) =&gt; a - b);" line97="        my_offset = pole[2];" line98="    }" line99="" line100="    //% block=&quot;kalibrovat siloměr (dílků na 1 N): %meritko&quot;" line101="    //% group=&quot;2. Síla&quot;" line102="    //% advanced=true" line103="    export function nastavitMeritko(meritko: number): void {" line104="        if (meritko == 0) meritko = 1;" line105="        my_scale = meritko;" line106="    }" line107="" line108="" line109="    // ==========================================" line110="    // --- 3. VZDÁLENOST ---" line111="    // ==========================================" line112="" line113="    // Globální proměnné pro paměť (sdílené mezi vzdáleností a rychlostí)" line114="    let _lastS = 0;" line115="    let _lastT = 0;" line116="" line117="    /**" line118="     * Změří vzdálenost." line119="     */" line120="    //% block=&quot;změřená vzdálenost v %jednotka | Trig %trigPin | Echo %echoPin&quot;" line121="    //% group=&quot;3. Vzdálenost&quot;" line122="    //% weight=80" line123="    export function zmeritVzdalenost(jednotka: VzdalenostniJednotka, trigPin: DigitalPin, echoPin: DigitalPin): number {" line124="        // Měříme v cm (1 = Centimeters)" line125="        let s = InternalSonar.ping(trigPin, echoPin, 1);" line126="" line127="        // Aktualizace paměti, aby přechod na měření rychlosti byl plynulý" line128="        if (s &gt; 0) {" line129="            _lastS = s;" line130="            _lastT = control.millis();" line131="        }" line132="" line133="        switch (jednotka) {" line134="            case VzdalenostniJednotka.Cm:" line135="                return s;" line136="            case VzdalenostniJednotka.M:" line137="                return s / 100;" line138="            default:" line139="                return 0;" line140="        }" line141="    }" line142="" line143="    //% block=&quot;změřit vzdálenost a kreslit graf v %jednotka | Trig %trigPin | Echo %echoPin&quot;" line144="    //% group=&quot;3. Vzdálenost&quot;" line145="    //% weight=79" line146="    export function zmeritVzdalenostAGraf(jednotka: VzdalenostniJednotka, trigPin: DigitalPin, echoPin: DigitalPin): void {" line147="        let val4 = zmeritVzdalenost(jednotka, trigPin, echoPin);" line148="" line149="        if (jednotka == VzdalenostniJednotka.Cm) serial.writeValue(&quot;Vzdalenost (cm)&quot;, val4);" line150="        else serial.writeValue(&quot;Vzdalenost (m)&quot;, val4);" line151="" line152="        // ZVÝŠENÁ PAUZA DLE POŽADAVKU" line153="        basic.pause(200);" line154="    }" line155="" line156="    // ==========================================" line157="    // --- 4. RYCHLOST (POKROČILÉ) ---" line158="    // ==========================================" line159="" line160="    /**" line161="     * Vypočítá rychlost. Tento blok sám měří vzdálenost a počítá změnu." line162="     */" line163="    //% block=&quot;změřená rychlost v %jednotka | Trig %trigPin | Echo %echoPin&quot;" line164="    //% group=&quot;4. Rychlost (Pokročilé)&quot;" line165="    //% weight=70" line166="    export function zmeritRychlost(jednotka: RychlostniJednotka, trigPin: DigitalPin, echoPin: DigitalPin): number {" line167="        // 1. Změříme aktuální data" line168="        let u = InternalSonar.ping(trigPin, echoPin, 1); // cm" line169="        let v = control.millis(); // ms" line170="" line171="        let v_cm_s = 0; // Výchozí rychlost (když stojíme nebo je chyba)" line172="" line173="        // 2. Aplikace tvého filtru" line174="        // - s musí být v rozmezí 0-400 (platné měření)" line175="        // - _lastS musí být &gt; 0 (tzn. minulé měření bylo platné)" line176="        if (u &gt; 0 &amp;&amp; u &lt; 400 &amp;&amp; _lastS &gt; 0) {" line177="" line178="            // Časový rozdíl v sekundách" line179="            let dt = (v - _lastT) / 1000.0;" line180="" line181="            // Filtr času: aspoň 20 ms rozestup, jinak je to šum" line182="            if (dt &gt; 0.02) {" line183="                // Výpočet rychlosti v cm/s" line184="                // Může vyjít záporná (přibližování) nebo kladná (vzdalování)" line185="                v_cm_s = (u - _lastS) / dt;" line186="            }" line187="        }" line188="" line189="        // 3. Aktualizace paměti" line190="        // Ukládáme vždy, pokud je měření platné, nebo pokud je to jen reset" line191="        _lastS = u;" line192="        _lastT = v;" line193="" line194="        // 4. Převod jednotek" line195="        if (jednotka == RychlostniJednotka.Ms) {" line196="            return v_cm_s / 100.0; // cm/s -&gt; m/s" line197="        } else {" line198="            return (v_cm_s / 100.0) * 3.6; // m/s -&gt; km/h" line199="        }" line200="    }" line201="" line202="    //% block=&quot;změřit rychlost a kreslit graf v %jednotka | Trig %trigPin | Echo %echoPin&quot;" line203="    //% group=&quot;4. Rychlost (Pokročilé)&quot;" line204="    //% weight=69" line205="    export function zmeritRychlostAGraf(jednotka: RychlostniJednotka, trigPin: DigitalPin, echoPin: DigitalPin): void {" line206="        // Zavoláme funkci pro rychlost (ta si sama změří i vzdálenost a aktualizuje stav)" line207="        let w = zmeritRychlost(jednotka, trigPin, echoPin);" line208="" line209="        // Do grafu pošleme rychlost" line210="        if (jednotka == RychlostniJednotka.Ms) serial.writeValue(&quot;Rychlost (m/s)&quot;, w);" line211="        else serial.writeValue(&quot;Rychlost (km/h)&quot;, w);" line212="" line213="        // A pošleme tam I VZDÁLENOST, abys viděl souvislost (jestli rychlost sedí k pohybu)" line214="        // Použijeme _lastS, což je hodnota, ze které se rychlost počítala" line215="        serial.writeValue(&quot;Poloha (cm)&quot;, _lastS);" line216="" line217="        // ZVÝŠENÁ PAUZA" line218="        basic.pause(200);" line219="    }" line220="}" numlines="221"></mutation><next><block type="typescript_statement" id="+na?o)b)+xH5C^Mb^bmJ"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace InternalSonar {" line1="    export function ping(trig: DigitalPin, echo: DigitalPin, unit: number, maxCmDistance = 500): number {" line2="        pins.setPull(trig, PinPullMode.PullNone);" line3="        pins.digitalWritePin(trig, 0);" line4="        control.waitMicros(2);" line5="        pins.digitalWritePin(trig, 1);" line6="        control.waitMicros(10);" line7="        pins.digitalWritePin(trig, 0);" line8="" line9="        const d = pins.pulseIn(echo, PulseValue.High, maxCmDistance * 58);" line10="" line11="        switch (unit) {" line12="            case 1: return Math.idiv(d, 58); // Centimeters" line13="            default: return d; // Microseconds" line14="        }" line15="    }" line16="}" numlines="17"></mutation></block></next></block></statement></block></xml>